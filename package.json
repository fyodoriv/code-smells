{
  "name": "code-smells",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Code smell detector for React/TypeScript repos. Thin wrapper over code-pushup with curated ESLint rules, research-backed signals (Tornhill temporal coupling, Nagappan team ownership), and monorepo support.",
  "license": "MIT",
  "scripts": {
    "check": "CP_TARGET=${CP_TARGET:-$PWD} npx code-pushup collect --persist.outputDir=reports --persist.format=json --persist.format=md",
    "format": "prettier --write .",
    "test": "node --test lib/**/*.spec.mjs"
  },
  "dependencies": {
    "@code-pushup/cli": "0.126.2",
    "@code-pushup/models": "0.126.2",
    "@code-pushup/utils": "0.126.2",
    "codeowners-utils": "1.0.2",
    "dependency-cruiser": "^17.3.10",
    "jscpd": "^4.0.9",
    "ts-morph": "^28.0.0"
  },
  "devDependencies": {
    "@code-pushup/coverage-plugin": "0.126.2",
    "@code-pushup/eslint-plugin": "0.126.2",
    "@code-pushup/js-packages-plugin": "0.126.2",
    "@code-pushup/jsdocs-plugin": "0.126.2",
    "@code-pushup/typescript-plugin": "0.126.2",
    "@typescript-eslint/parser": "8.58.2",
    "eslint": "9.39.4",
    "eslint-plugin-formatjs": "6.4.5",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-perf": "3.3.3",
    "eslint-plugin-sonarjs": "4.0.3",
    "eslint-plugin-testing-library": "7.16.2",
    "knip": "6.5.0",
    "simple-git": "3.36.0",
    "type-coverage": "2.29.7",
    "typescript": "^5.5.0"
  }
}
