{
  "name": "code-smells",
  "version": "0.2.10",
  "type": "module",
  "description": "Code smell detector for React/TypeScript repos. Thin wrapper over code-pushup with curated ESLint rules, research-backed signals (Tornhill temporal coupling, Nagappan team ownership), and monorepo support.",
  "keywords": [
    "code-quality",
    "code-smells",
    "static-analysis",
    "react",
    "typescript",
    "eslint",
    "code-pushup",
    "temporal-coupling",
    "monorepo",
    "ci"
  ],
  "license": "MIT",
  "author": "fyodoriv",
  "homepage": "https://github.com/fyodoriv/code-smells#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fyodoriv/code-smells.git"
  },
  "bugs": {
    "url": "https://github.com/fyodoriv/code-smells/issues"
  },
  "bin": {
    "code-smells": "./bin/code-smells.mjs"
  },
  "files": [
    "bin",
    "lib",
    "plugins",
    "eslint-rules",
    "code-pushup.config.mjs",
    "eslint.target-rules.mjs",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "check": "CP_TARGET=${CP_TARGET:-$PWD} node ./bin/code-smells.mjs --persist.outputDir=reports --persist.format=json --persist.format=md",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@code-pushup/cli": "0.126.2",
    "@code-pushup/coverage-plugin": "0.126.2",
    "@code-pushup/js-packages-plugin": "0.126.2",
    "@code-pushup/models": "0.126.2",
    "@code-pushup/typescript-plugin": "0.126.2",
    "@code-pushup/utils": "0.126.2",
    "@typescript-eslint/parser": "8.58.2",
    "codeowners-utils": "1.0.2",
    "dependency-cruiser": "^17.3.10",
    "eslint": "9.39.4",
    "eslint-plugin-formatjs": "6.4.5",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-perf": "3.3.3",
    "eslint-plugin-sonarjs": "4.0.3",
    "eslint-plugin-testing-library": "7.16.2",
    "jscpd": "^4.0.9",
    "knip": "6.5.0",
    "simple-git": "3.36.0",
    "type-coverage": "2.29.7",
    "type-coverage-core": "2.29.7",
    "typescript": "^5.5.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.5",
    "prettier": "^3.3.0",
    "vitest": "4.1.5"
  }
}
